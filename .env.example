# 12-Factor App Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Mode
# =============================================================================
ENV_MODE=development
LOG_LEVEL=INFO

# =============================================================================
# LLM Configuration
# =============================================================================
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3

# =============================================================================
# Database
# =============================================================================
DB_TYPE=sqlite
DATABASE_URL=sqlite:///./job_agent.db

# =============================================================================
# Email Notifications (Gmail SMTP)
# =============================================================================
SENDER_EMAIL=your.email@gmail.com
SENDER_PASSWORD=your-gmail-app-password
RECIPIENT_EMAIL=recipient@example.com

# =============================================================================
# SMS Notifications (Twilio)
# =============================================================================
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890
RECIPIENT_PHONE=+0987654321

# =============================================================================
# AUTH CREDENTIALS
# Configure only the boards you intend to use.
# =============================================================================

# LinkedIn OAuth 2.0
# Register an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Adzuna API key (free tier at https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_API_KEY=
ADZUNA_COUNTRY=us   # us, gb, au, ca, de, fr, in, nl, nz, pl, ru, sg, za

# Indeed Publisher API (https://ads.indeed.com/jobroll/xmlfeed)
INDEED_PUBLISHER_ID=

# ZipRecruiter Partner API (https://app.ziprecruiter.com/partners)
ZIPRECRUITER_API_KEY=

# GitHub personal access token (optional – avoids 60 req/h unauthenticated limit)
GITHUB_TOKEN=

# The Muse optional API key (lifts rate limit)
THE_MUSE_API_KEY=

# =============================================================================
# Job Search Sources
# =============================================================================

# --- Tier 1: Always-on free public JSON APIs (no auth needed) ---
REMOTE_OK_ENABLED=true
REMOTIVE_ENABLED=true
ARBEITNOW_ENABLED=true        # https://www.arbeitnow.com/
HIMALAYAS_ENABLED=true        # https://himalayas.app/
JOBICY_ENABLED=true           # https://jobicy.com/
THE_MUSE_ENABLED=true         # https://www.themuse.com/

# --- Tier 2: RSS feeds (no auth needed) ---
WE_WORK_REMOTELY_ENABLED=true

# --- Tier 3: API-key required ---
ADZUNA_ENABLED=false
INDEED_ENABLED=false
ZIPRECRUITER_ENABLED=false

# --- Tier 4: OAuth 2.0 ---
LINKEDIN_ENABLED=false

# --- Tier 5: ATS aggregators (public APIs) ---
LEVER_ENABLED=true
ASHBY_ENABLED=true
GREENHOUSE_ENABLED=true

# ATS company slugs (comma-separated, no spaces)
LEVER_COMPANIES=stripe,airbnb,notion,figma,twilio,datadog,snowflake,cloudflare,elastic,gitlab
ASHBY_COMPANIES=linear,cal.com,resend,raycast,polymarket,loom,retool,dbt-labs
GREENHOUSE_COMPANIES=shopify,discord,reddit,intercom,dropbox,squarespace,duolingo,eventbrite,hubspot,zendesk

# --- Deprecated stubs (no working implementation – keep false) ---
GLASSDOOR_ENABLED=false
MONSTER_ENABLED=false
CAREERJET_ENABLED=false
JOOBLE_ENABLED=false
SIMPLYHIRED_ENABLED=false

# =============================================================================
# Application Settings
# =============================================================================
MAX_JOBS_PER_SEARCH=20
SEARCH_INTERVAL_HOURS=24
AUTO_APPLY_ENABLED=false
